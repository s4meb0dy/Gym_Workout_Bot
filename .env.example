# Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Server port (Render sets this automatically)
PORT=3000

# SQLite database path
DATABASE_URL="file:./dev.db"

# Timezone for reminders/digest (IANA name)
TZ_NAME=Europe/Brussels

# Path to the SQLite file (used for backups)
DATABASE_FILE=prisma/dev.db

# Set to "false" to disable reminders/backup scheduler
ENABLE_SCHEDULER=true

# Public URL of this app (e.g. https://my-bot.onrender.com).
# Used for keep-alive self-ping so the host does not sleep.
APP_URL=

# How often (minutes) to self-ping APP_URL/health
KEEPALIVE_MINUTES=10

# Google Gemini API key for photo-based calorie/macro recognition
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the vision model
GEMINI_MODEL=gemini-3.5-flash
